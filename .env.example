# Local app
SHOULDER_DIGEST_HOST=127.0.0.1
SHOULDER_DIGEST_PORT=8765
SHOULDER_DIGEST_DB=.pubmed_digest/digest.sqlite3
SHOULDER_DIGEST_DAILY_TIME=07:00
SHOULDER_DIGEST_PUBLIC_BASE_URL=
SHOULDER_DIGEST_TOP_PAPER_COUNT=3
SHOULDER_DIGEST_PUBMED_LOOKBACK_DAYS=3
SHOULDER_DIGEST_AUTO_SEND=0

# PubMed / NCBI E-utilities. NCBI_API_KEY is optional but recommended for higher rate limits.
NCBI_API_KEY=
NCBI_EMAIL=
NCBI_TOOL=shoulder-digest

# Codex app-server. Leave empty to auto-prefer the standalone Codex CLI under %LOCALAPPDATA%.
CODEX_BIN=
CODEX_MODEL=
CODEX_GENERATED_IMAGES_DIR=
SHOULDER_DIGEST_MOCK_AI=0

# Notion API
NOTION_TOKEN=
# Prepared database created by the Notion connector:
# c78096bc6401494999e598ed022e84a8
NOTION_DATABASE_ID=
NOTION_VERSION=2022-06-28
# NOTION_API_BASE_URL=https://api.notion.com

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_GROUP_ID=
# LINE_API_BASE_URL=https://api.line.me
