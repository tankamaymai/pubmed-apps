# Local app
SHOULDER_DIGEST_HOST=127.0.0.1
SHOULDER_DIGEST_PORT=8765
SHOULDER_DIGEST_DB=.pubmed_digest/digest.sqlite3
SHOULDER_DIGEST_DAILY_TIME=07:00
SHOULDER_DIGEST_PUBLIC_BASE_URL=
# Auto-updated on startup by: python -m shoulder_digest sync-ngrok-url
# (also synced automatically when serve / run / approve-send starts)
SHOULDER_DIGEST_TOP_PAPER_COUNT=1
SHOULDER_DIGEST_PUBMED_LOOKBACK_DAYS=90
SHOULDER_DIGEST_PUBMED_MAX_LOOKBACK_DAYS=1825
SHOULDER_DIGEST_AUTO_SEND=0

# PubMed / NCBI E-utilities. NCBI_API_KEY is optional but recommended for higher rate limits.
NCBI_API_KEY=
NCBI_EMAIL=
NCBI_TOOL=shoulder-digest

# Codex app-server. Leave empty to auto-prefer the standalone Codex CLI under %LOCALAPPDATA%.
CODEX_BIN=
CODEX_MODEL=
CODEX_GENERATED_IMAGES_DIR=
CODEX_TURN_TIMEOUT_SECONDS=600
CODEX_IMAGE_TURN_TIMEOUT_SECONDS=1800
CODEX_IMAGE_WAIT_SECONDS=120
SHOULDER_DIGEST_MOCK_AI=0

# Notion API. Share the archive database with your integration before use.
NOTION_TOKEN=
# Prepared database created by the Notion connector:
# c78096bc6401494999e598ed022e84a8
NOTION_DATABASE_ID=
NOTION_VERSION=2022-06-28
# NOTION_API_BASE_URL=https://api.notion.com

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_GROUP_ID=
# LINE_API_BASE_URL=https://api.line.me

# Obsidian vault (optional). Daily digest notes and images are saved here.
OBSIDIAN_VAULT=
OBSIDIAN_NOTES_DIR=PubMed肩関節
